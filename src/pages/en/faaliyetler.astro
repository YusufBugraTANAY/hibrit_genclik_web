---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const activityCategories = [
  {
    id: 'international',
    title: t('activities.international.title'),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" x2="22" y1="12" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
    items: lang === 'tr' 
      ? ['Gençlik Değişimleri', 'Eğitim Kursları', 'Dayanışma Projeleri (ESC)']
      : ['Youth Exchanges', 'Training Courses', 'Solidarity Projects (ESC)']
  },
  {
    id: 'local',
    title: t('activities.local.title'),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 22 8-4V6l-8-4-8 4v12l8 4z"/></svg>`,
    items: lang === 'tr'
      ? ['Gençlik Zirveleri', 'Kültürel Etkinlikler', 'Sosyal Sorumluluk Faaliyetleri']
      : ['Youth Summits', 'Cultural Events', 'Social Responsibility Activities']
  },
  {
    id: 'workshops',
    title: t('activities.workshops.title'),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h9z"/></svg>`,
    items: lang === 'tr'
      ? ['Dijital Okuryazarlık', 'Proje Yönetimi Eğitimi', 'Kişisel Gelişim Atölyeleri']
      : ['Digital Literacy', 'Project Management Training', 'Personal Development Workshops']
  }
];
---

<Layout title={t('nav.activities')}>
  <section class="pt-32 pb-16 bg-mint/5 border-b border-mint/10">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-deep mb-6 leading-tight">
          {t('activities.title')}
        </h1>
        <p class="text-xl text-slate-text leading-relaxed">
          {lang === 'tr' 
            ? 'Gençleri geleceğe hazırlayan, hem yerel hem de uluslararası düzeyde yürüttüğümüz faaliyetlerimiz.'
            : 'Our activities at both local and international levels, preparing youth for the future.'}
        </p>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        {activityCategories.map((category) => (
          <div class="glass-card p-10 bg-white border-slate-200 flex flex-col hover:-translate-y-2 transition-all duration-300">
            <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary mb-8" set:html={category.icon}></div>
            <h3 class="text-2xl font-bold text-slate-deep mb-6">{category.title}</h3>
            <ul class="space-y-4 flex-grow">
              {category.items.map((item) => (
                <li class="flex items-center gap-3 text-slate-text">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-mint"><polyline points="20 6 9 17 4 12"/></svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 bg-slate-50 border-t border-slate-200">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-deep mb-8">{lang === 'tr' ? 'Faaliyetlerimize Katılmak İster Misin?' : 'Want to Join Our Activities?'}</h2>
      <a href={lang === 'tr' ? '/gonulluluk/' : '/en/gonulluluk/'} class="inline-block px-10 py-4 bg-primary hover:bg-primary-dark text-white font-bold rounded-full transition-all transform hover:scale-105 shadow-md text-lg">
        {t('nav.volunteer')}
      </a>
    </div>
  </section>
</Layout>
