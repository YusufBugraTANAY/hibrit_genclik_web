---
import Layout from '../../layouts/Layout.astro';
import association from '../../data/association.json';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('nav.about')}>
  <!-- Hero Section -->
  <section class="pt-32 pb-16 bg-slate-50 border-b border-slate-200 overflow-hidden relative">
    <div class="absolute top-0 right-0 w-1/3 h-full bg-primary/5 -skew-x-12 transform translate-x-1/2"></div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-deep mb-6 leading-tight">
          {t('about.title')}
        </h1>
        <p class="text-xl text-slate-text leading-relaxed">
          {association.name[lang]} {lang === 'tr' ? 'olarak gençlerin potansiyellerini keşfetmelerine yardımcı oluyoruz.' : 'helps youth discover their potential.'}
        </p>
      </div>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="p-10 rounded-3xl bg-mint/10 border border-mint/20">
          <div class="w-16 h-16 rounded-2xl bg-white flex items-center justify-center text-primary shadow-sm mb-8">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
          </div>
          <h2 class="text-3xl font-bold text-slate-deep mb-6">{t('about.mission.title')}</h2>
          <p class="text-slate-text leading-relaxed text-lg">
            {association.vision[lang]}
          </p>
        </div>
        <div class="p-10 rounded-3xl bg-primary/5 border border-primary/10">
          <div class="w-16 h-16 rounded-2xl bg-white flex items-center justify-center text-primary shadow-sm mb-8">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <h2 class="text-3xl font-bold text-slate-deep mb-6">{t('about.vision.title')}</h2>
          <p class="text-slate-text leading-relaxed text-lg">
            {lang === 'tr' 
              ? 'Gençlik çalışmalarında hibrit metodları (dijital ve fiziksel) en verimli şekilde kullanarak uluslararası standartlarda bir gençlik kulübü olmak.'
              : 'To be a youth club at international standards by using hybrid methods (digital and physical) in youth work in the most efficient way.'}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- History -->
  <section class="py-24 bg-slate-50 relative">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-slate-deep mb-12 text-center">{t('about.history.title')}</h2>
        <div class="relative border-l-2 border-primary/20 pl-10 py-4 space-y-12">
          <div class="relative">
            <div class="absolute -left-[51px] top-0 w-5 h-5 rounded-full bg-primary border-4 border-white shadow-sm"></div>
            <span class="text-primary font-bold text-lg">{association.established}</span>
            <h3 class="text-xl font-bold text-slate-deep mt-2 mb-4">{lang === 'tr' ? 'Kuruluş' : 'Establishment'}</h3>
            <p class="text-slate-text leading-relaxed">
              {lang === 'tr' 
                ? 'Hibrit Gençlik Kulübü Derneği, gençlerin teknoloji ve sosyal becerilerini hibrit bir modelle geliştirmek amacıyla İstanbul merkezli olarak kuruldu.'
                : 'Hybrid Youth Club Association was established in Istanbul to develop the technology and social skills of young people with a hybrid model.'}
            </p>
          </div>
          <div class="relative">
            <div class="absolute -left-[51px] top-0 w-5 h-5 rounded-full bg-mint border-4 border-white shadow-sm"></div>
            <span class="text-mint font-bold text-lg">2023 - 2024</span>
            <h3 class="text-xl font-bold text-slate-deep mt-2 mb-4">{lang === 'tr' ? 'Uluslararası Projeler' : 'International Projects'}</h3>
            <p class="text-slate-text leading-relaxed">
              {lang === 'tr' 
                ? 'Kısa sürede birçok Erasmus+ projesine imza atarak yüzlerce gence Avrupa fırsatlarını ulaştırdı.'
                : 'By signing many Erasmus+ projects in a short time, it brought European opportunities to hundreds of young people.'}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
