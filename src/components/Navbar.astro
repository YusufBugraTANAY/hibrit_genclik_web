---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const navItems = [
  { label: t('nav.home'), href: translatePath('/') },
  { label: t('nav.about'), href: translatePath('/kurumsal/') },
  { label: t('nav.activities'), href: translatePath('/faaliyetler/') },
  { label: t('nav.projects'), href: translatePath('/projeler/') },
  { label: t('nav.volunteer'), href: translatePath('/gonulluluk/') },
  { label: t('nav.contact'), href: translatePath('/iletisim/') },
];

const currentPath = Astro.url.pathname;
const hasTrailingSlash = currentPath.endsWith('/');
const altLang = lang === 'tr' ? 'en' : 'tr';

let altLangUrl;
if (lang === 'tr') {
  // From TR to EN
  const path = currentPath === '/' ? '' : currentPath;
  altLangUrl = `/en${path}${path.endsWith('/') || path === '' ? '' : '/'}`;
} else {
  // From EN to TR
  altLangUrl = currentPath.replace(/^\/en/, '') || '/';
  if (!altLangUrl.endsWith('/')) altLangUrl += '/';
}
---

<header class="sticky top-0 z-50 glass">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href={translatePath('/')} class="flex items-center gap-3 group">
        <img 
          src="/images/logo.jpg" 
          alt="Hibrit Gençlik Logo" 
          class="h-12 w-auto group-hover:scale-105 transition-transform duration-300 rounded-lg"
          onerror="this.src='/favicon.svg'; this.className='w-10 h-10 rounded-xl bg-gradient-to-tr from-primary to-mint p-2';"
        />
        <div class="flex flex-col">
          <span class="font-bold text-lg leading-tight tracking-tight text-slate-deep group-hover:text-primary transition-colors">Hibrit Gençlik</span>
          <span class="text-xs text-slate-text uppercase tracking-widest font-medium">Kulübü Derneği</span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8">
        <ul class="flex items-center gap-6">
          {navItems.map(item => (
            <li>
              <a 
                href={item.href} 
                class="text-sm font-medium text-slate-text hover:text-primary transition-colors relative after:absolute after:-bottom-1 after:left-0 after:w-0 after:h-0.5 after:bg-primary hover:after:w-full after:transition-all after:duration-300"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
        
        <div class="flex items-center gap-4 border-l border-slate-200 pl-4">
          <a href={altLangUrl} class="text-xs font-bold text-slate-text hover:text-primary transition-colors flex items-center bg-slate-100 hover:bg-slate-200 rounded px-2 py-1">
            {altLang.toUpperCase()}
          </a>
          
          <a href={translatePath('/gonulluluk/')} class="bg-primary hover:bg-primary-dark text-white px-5 py-2 rounded-full font-semibold text-sm transition-all transform hover:scale-105 shadow-md">
            {t('nav.volunteer')}
          </a>
        </div>
      </nav>

      <!-- Mobile Menu Button -->
      <div class="flex items-center gap-4 md:hidden">
        <a href={altLangUrl} class="text-xs font-bold text-slate-text hover:text-primary transition-colors bg-slate-100 rounded px-2 py-1">
          {altLang.toUpperCase()}
        </a>
        <button id="mobile-menu-toggle" class="text-slate-text hover:text-primary transition-colors focus:outline-none">
          <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
          <svg id="close-icon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/></svg>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Menu Drawer (Outside Header to bypass stacking context) -->
<div id="mobile-menu-overlay" class="fixed inset-0 bg-slate-900/60 backdrop-blur-md z-[9998] hidden opacity-0 transition-opacity duration-300"></div>

<div id="mobile-menu-drawer" class="fixed inset-y-0 right-0 w-[85%] max-w-sm bg-white z-[9999] hidden transform translate-x-full transition-transform duration-300 shadow-2xl overflow-y-auto">
  <div class="flex flex-col h-full">
    <!-- Drawer Header -->
    <div class="flex items-center justify-between p-6 border-b border-slate-100 bg-white sticky top-0 z-10">
      <div class="flex items-center gap-3">
        <img src="/images/logo.jpg" alt="Logo" class="h-8 w-auto rounded" />
        <span class="font-bold text-slate-deep">Hibrit Gençlik</span>
      </div>
      <button id="mobile-menu-close" class="p-2 text-slate-text hover:text-primary transition-colors bg-slate-50 rounded-full">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/></svg>
      </button>
    </div>

    <!-- Drawer Content -->
    <div class="flex-grow p-6">
      <ul class="flex flex-col gap-2">
        {navItems.map(item => (
          <li>
            <a 
              href={item.href} 
              class="text-lg font-semibold text-slate-deep hover:text-primary hover:bg-slate-50 transition-all block px-4 py-4 rounded-xl border-b border-slate-50"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Drawer Footer -->
    <div class="p-6 border-t border-slate-100 bg-slate-50 mt-auto">
      <a href={translatePath('/gonulluluk/')} class="block w-full bg-primary text-white text-center py-4 rounded-2xl font-bold text-lg shadow-lg active:scale-95 transition-all">
        {t('nav.volunteer')}
      </a>
      <p class="text-center text-xs text-slate-text mt-4 opacity-60">© 2026 Hibrit Gençlik Derneği</p>
    </div>
  </div>
</div>

<script>
  // Script logic remains same but ensuring it targets the new elements
  const setupMenu = () => {
    const toggleBtn = document.getElementById('mobile-menu-toggle');
    const closeBtn = document.getElementById('mobile-menu-close');
    const overlay = document.getElementById('mobile-menu-overlay');
    const drawer = document.getElementById('mobile-menu-drawer');

    if (!toggleBtn || !closeBtn || !overlay || !drawer) return;

    function openMenu() {
      overlay.classList.remove('hidden');
      drawer.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      setTimeout(() => {
        overlay.classList.add('opacity-100');
        drawer.classList.remove('translate-x-full');
      }, 10);
    }

    function closeMenu() {
      overlay.classList.remove('opacity-100');
      drawer.classList.add('translate-x-full');
      document.body.style.overflow = '';
      setTimeout(() => {
        overlay.classList.add('hidden');
        drawer.classList.add('hidden');
      }, 300);
    }

    toggleBtn.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);
    overlay.addEventListener('click', closeMenu);

    const menuLinks = drawer.querySelectorAll('a');
    menuLinks.forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  };

  // Run on initial load
  setupMenu();
  
  // Also run on Astro page changes if needed
  document.addEventListener('astro:page-load', setupMenu);
</script>
