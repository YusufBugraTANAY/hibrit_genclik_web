---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import NewsCarousel from '../components/NewsCarousel.jsx';
import TeamCard from '../components/TeamCard.astro';
import association from '../data/association.json';
import projects from '../data/projects.json';

import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<Layout>
  <!-- Hero Section -->
  <Hero />

  <!-- News & Events Carousel Section -->
  <section class="py-24 relative relative z-10">
    <div class="container mx-auto px-4">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
        <div>
          <h2 class="text-3xl md:text-5xl font-bold text-slate-deep mb-4">{t('projects.title')} <span class="text-gradient">{t('projects.title.gradient')}</span></h2>
          <p class="text-slate-text max-w-2xl leading-relaxed">
            {t('projects.subtitle')}
          </p>
        </div>
        <a href={translatePath('/projeler/')} class="inline-flex items-center text-primary font-semibold hover:text-primary-dark transition-colors group">
          {t('projects.viewAll')}
          <svg class="w-5 h-5 ml-2 transform group-hover:translate-x-2 transition-transform" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
      
      <!-- Swiper Carousel Component (Client Load) -->
      <NewsCarousel projects={projects} lang={lang} client:load />
    </div>
  </section>

  <!-- Team Section -->
  <section class="py-24 bg-white relative border-t border-slate-200">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl md:text-5xl font-bold text-slate-deep mb-6">{t('team.title')} <span class="text-gradient">{t('team.title.gradient')}</span></h2>
        <p class="text-slate-text leading-relaxed">
          {t('team.subtitle')}
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {association.team.map((member) => (
          <TeamCard member={member} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-primary/5"></div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="glass-card p-12 md:p-20 text-center border-slate-200 bg-white">
        <h2 class="text-3xl md:text-5xl font-bold text-slate-deep mb-6">{t('cta.title')}</h2>
        <p class="text-lg text-slate-text max-w-2xl mx-auto mb-10">
          {t('cta.subtitle')}
        </p>
        <a href={translatePath('/gonulluluk/')} class="inline-block px-10 py-5 bg-primary hover:bg-primary-dark text-white font-bold rounded-full transition-all transform hover:scale-105 shadow-md text-lg">
          {t('cta.btn')}
        </a>
      </div>
    </div>
  </section>
</Layout>
